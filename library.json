    "soil-moisture",
    "wetness",
    "wet-dry",
    "electrode-sensor",
    "conductivity-trend",
    "capacitive-sensor",
    "surface-sensing",
    "brine",
    "ice-risk",
    "low-power",
    "industrial-iot",
    "sensor-calibration",
    "signal-filtering"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Parvaz-Jamei/PulseWetProbe-Arduino.git"
  },
  "authors": [
    {
      "name": "Parvaz Jamei",
